{
  "name": "@sabahattinkalkan/gpulse",
  "version": "1.0.1",
  "description": "The Missing GitHub CLI Toolkit — standup, stats, changelog, health, review, digest",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "gpulse": "dist/index.js"
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --clean",
    "dev": "tsup src/index.ts --format esm --watch",
    "start": "node dist/index.js",
    "lint": "eslint src/",
    "test": "vitest run",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "github",
    "cli",
    "git",
    "standup",
    "changelog",
    "stats",
    "developer-tools",
    "productivity",
    "review",
    "digest"
  ],
  "author": "Scuton Technology <info@scuton.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/scuton-technology/ghx.git"
  },
  "homepage": "https://github.com/scuton-technology/ghx",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "chalk": "^5.6.2",
    "commander": "^14.0.3",
    "dayjs": "^1.11.20",
    "octokit": "^5.0.5",
    "ora": "^9.3.0"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "eslint": "^10.0.3",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  }
}
